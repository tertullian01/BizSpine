# Subdirectory path when hosted below a domain root (must start and end with /).
# Example: site at https://techdiplomacy.dev/BizSpine → VITE_BASE_PATH=/BizSpine/
# VITE_BASE_PATH=/BizSpine/

# API base URL (no trailing slash).
# Development: leave unset to use Vite proxy at /backend → http://localhost:8000
# Shared hosting example: https://techdiplomacy.dev/BizSpine/api
# VITE_API_BASE_URL=https://techdiplomacy.dev/BizSpine/api
