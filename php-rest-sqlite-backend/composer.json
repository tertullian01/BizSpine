{
    "name": "smallbusiness/php-rest-sqlite-backend",
    "description": "A simple PHP REST API with SQLite database.",
    "type": "project",
    "require": {
        "php": "^7.4 || ^8.0",
        "slim/slim": "^4.0",
        "slim/psr7": "^1.0",
        "vlucas/phpdotenv": "^5.0",
        "firebase/php-jwt": "^6.11",
        "respect/validation": "^2.0",
        "symfony/cache": "^5.0",
        "predis/predis": "^2.0",
        "monolog/monolog": "^2.0",
        "zircote/swagger-php": "^4.0",
        "phpmailer/phpmailer": "^6.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "robmorgan/phinx": "^0.16.10",
        "squizlabs/php_codesniffer": "^3.7",
        "phpstan/phpstan": "^1.10"
    },
    "scripts": {
        "test": "phpunit",
        "cs": "phpcs --standard=PSR12 src/ tests/",
        "cs:fix": "phpcbf --standard=PSR12 src/ tests/",
        "stan": "phpstan analyse --configuration=phpstan.neon --memory-limit=256M",
        "qa": [
            "@cs",
            "@stan",
            "@test"
        ]
    }
}
