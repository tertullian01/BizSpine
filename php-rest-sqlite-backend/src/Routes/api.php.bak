<?php
declare(strict_types=1);

use App\Controllers\HealthController;
use App\Controllers\AuthController;

// simple router (expand as needed)
$method = $_SERVER['REQUEST_METHOD'];
$uri = parse_url($_SERVER['REQUEST_URI'], PHP_URL_PATH);

$routes = [
    "GET /health" => [HealthController::class, 'index'],
    "POST /auth/register" => [AuthController::class, 'register'],
    "POST /auth/login" => [AuthController::class, 'login'],
    "POST /auth/refresh" => [AuthController::class, 'refresh'],
    "POST /auth/logout" => [AuthController::class, 'logout'],
    "GET /auth/oauth/redirect" => [AuthController::class, 'oauthRedirect'],
    "GET /auth/oauth/callback" => [AuthController::class, 'oauthCallback'],
];

$key = "$method $uri";
if (!isset($routes[$key])) {
    http_response_code(404);
    header('Content-Type: application/json');
    echo json_encode(['error' => 'Not Found']);
    exit;
}

[$class, $action] = $routes[$key];
$controller = new $class(require __DIR__ . '/../../protected/config/config.php');
$response = $controller->$action();