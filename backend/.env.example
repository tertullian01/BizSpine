# Copy to .env and set a long random value (required in production).
# The web installer creates this file automatically on shared hosting.
JWT_SECRET=

# Storefront base URL (scheme + host, no trailing slash).
# Used to build password reset links and should match your CORS storefront origin(s).
STOREFRONT_URL=https://INSERT_URL_HERE

# Optional: override the full reset page URL (default: STOREFRONT_URL + /reset.html)
# PASSWORD_RESET_URL=https://INSERT_URL_HERE/reset.html

# Optional: reset page path when using STOREFRONT_URL (default: /reset.html)
# PASSWORD_RESET_PATH=/reset.html

# Comma-separated storefront origins allowed to call the API (must match browser Origin exactly).
CORS_ALLOWED_ORIGINS=https://INSERT_URL_HERE,https://www.INSERT_URL_HERE

# Never enable on public hosts (disables setup/diagnostic routes).
ALLOW_INSECURE_SETUP=false
