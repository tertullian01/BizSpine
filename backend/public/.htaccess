RewriteEngine On

# Route site root and API paths through index.php (directory "/" is not rewritten by the rule below).
RewriteRule ^$ index.php [L]

# CORS is now handled by PHP in index.php

# Let PHP/Slim handle OPTIONS requests instead of Apache

# Allow direct access to .php files
RewriteCond %{REQUEST_FILENAME} \.php$
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?q=$1 [L,QSA]

# Deny access to the protected directory
<Directory "/path/to/backend/protected">
    Order Allow,Deny
    Deny from all
</Directory>